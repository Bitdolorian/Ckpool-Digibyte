###############################################
# GLOBAL IGNORE — REPO ROOT
###############################################

# Logs
*.log
*.pid
*.sock
*.tmp
logs/
tmp/

# OS junk
.DS_Store
Thumbs.db

###############################################
# CKPOOL SOURCE
###############################################

# Autotools build artifacts
ckpool-source/Makefile
ckpool-source/Makefile.in
ckpool-source/Makefile.am
ckpool-source/aclocal.m4
ckpool-source/autom4te.cache/
ckpool-source/compile
ckpool-source/config.guess
ckpool-source/config.h
ckpool-source/config.h.in
ckpool-source/config.log
ckpool-source/config.status
ckpool-source/config.sub
ckpool-source/configure
ckpool-source/configure.ac
ckpool-source/depcomp
ckpool-source/install-sh
ckpool-source/libtool
ckpool-source/ltmain.sh
ckpool-source/missing
ckpool-source/stamp-h1
ckpool-source/test-driver
ckpool-source/tests/

# CKPool runtime logs
ckpool-source/logs/
ckpool-source/*.log

# Sensitive configs (you commit sanitized versions manually)
ckpool-source/ckpool-dgb.conf.backup
ckpool-source/*.bak

###############################################
# CKSTATS (Next.js + TypeORM)
###############################################

# Environment files (never commit secrets)
ckstats/.env
ckstats/.env.local
ckstats/.env.production
ckstats/.env.development

# Build artifacts
ckstats/.next/
ckstats/dist/

# Dependencies
ckstats/node_modules/

# Lockfiles (you use pnpm)
ckstats/package-lock.json

# Tests (you removed them)
ckstats/__tests__/
ckstats/jest.config.js
ckstats/jest.setup.js

###############################################
# DIGIBYTE CORE SOURCE (UNBUILT)
###############################################

# Build outputs (if someone builds locally)
digibyte/src/*.o
digibyte/src/*.a
digibyte/src/*.so
digibyte/src/.deps/
digibyte/src/.objs/

# Autotools outputs
digibyte/Makefile
digibyte/Makefile.in
digibyte/Makefile.am
digibyte/config.log
digibyte/config.status
digibyte/config.cache
digibyte/autom4te.cache/
digibyte/build-aux/

# Runtime blockchain data (never commit)
digibyte/wallet.dat
digibyte/peers.dat
digibyte/mempool.dat
digibyte/banlist.dat
digibyte/blocks/
digibyte/chainstate/

###############################################
# BINARIES
###############################################

bin/*.pid
bin/*.tmp
bin/*.log
