# GLOBAL
*.log
*.pid
*.sock
*.tmp
logs/
tmp/
.DS_Store
Thumbs.db

###############################################
# CKPOOL SOURCE — ignore ONLY build artifacts
###############################################
ckpool-source/*.o
ckpool-source/*.a
ckpool-source/*.so
ckpool-source/autom4te.cache/
ckpool-source/config.log
ckpool-source/config.status
ckpool-source/Makefile
ckpool-source/Makefile.in
ckpool-source/Makefile.am
ckpool-source/libtool
ckpool-source/compile
ckpool-source/depcomp
ckpool-source/install-sh
ckpool-source/ltmain.sh
ckpool-source/missing
ckpool-source/stamp-h1
ckpool-source/test-driver

###############################################
# DIGIBYTE CORE — ignore ONLY build artifacts
###############################################
digibyte-core/src/*.o
digibyte-core/src/*.a
digibyte-core/src/*.so
digibyte-core/src/.deps/
digibyte-core/src/.objs/
digibyte-core/autom4te.cache/
digibyte-core/build-aux/
digibyte-core/config.log
digibyte-core/config.status
digibyte-core/Makefile
digibyte-core/Makefile.in
digibyte-core/Makefile.am

# DO NOT ignore .cpp, .h, .in, .m4, or source folders

###############################################
# CKSTATS — ignore ONLY build artifacts
###############################################
ckstats/.next/
ckstats/dist/
ckstats/node_modules/
ckstats/.env
ckstats/package-lock.json

###############################################
# BLOCKCHAIN DATA — never commit
###############################################
digibyte-core/wallet.dat
digibyte-core/peers.dat
digibyte-core/mempool.dat
digibyte-core/banlist.dat
digibyte-core/blocks/
digibyte-core/chainstate/

###############################################
# BIN
###############################################
bin/*.pid
bin/*.tmp
bin/*.log
